# rag-retriever configuration. Copy to .env and edit, or set these in your shell.
# The same code serves a fully-local setup or a domestic cloud API setup.

# Which embedding backend: local | ollama | openai
#   local  = fastembed, in-process, 100% offline, no server (heavier first install)
#   ollama = Ollama daemon (remote URLs require RAG_CLOUD_CONSENT=1)
#   openai = any OpenAI-compatible /embeddings API (e.g. SiliconFlow) — needs a key
RAG_EMBED_BACKEND=local

# Embedding model id (must match the backend). Leave unset to use the backend default.
#   local default is probed at install time (a Chinese-capable bge model)
#   ollama: bge-m3        openai/SiliconFlow: BAAI/bge-m3
# RAG_EMBED_MODEL=BAAI/bge-m3

# --- ollama backend ---
RAG_OLLAMA_URL=http://localhost:11434

# --- openai-compatible backend (SiliconFlow shown) ---
RAG_OPENAI_BASE_URL=https://api.siliconflow.cn/v1
RAG_OPENAI_API_KEY=
# Required for OpenAI-compatible APIs and non-loopback RAG_OLLAMA_URL values.
RAG_CLOUD_CONSENT=0

# Where the vector store lives (LanceDB directory).
# RAG_DATA_DIR=C:\Users\you\.rag-retriever\data

# Chunking (token-based). bge-m3 handles long chunks well.
RAG_CHUNK_TOKENS=800
RAG_CHUNK_OVERLAP=100

# Max texts per request to the HTTP embedders (ollama/openai); keeps big
# documents under provider payload/timeout limits. Ignored by the local backend.
RAG_EMBED_BATCH_SIZE=64
